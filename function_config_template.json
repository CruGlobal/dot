{
  "name": "FUNCTION_NAME",
  "entry-point": "hello_http",
  "runtime": "python312",
  "trigger-http": true,
  "region": "GCP_REGION",
  "gen2": true,
  "source": "./FUNCTION_NAME",
  "set-secrets": [
    "API_KEY=FUNCTION_NAME_API_KEY:latest",
    "API_SECRET=FUNCTION_NAME_API_SECRET:latest"
  ],
  "build-service-account": "projects/GCP_PROJECT_ID/serviceAccounts/GCP_SERVICE_ACCOUNT_EMAIL",
  "run-service-account": "RUN_SERVICE_ACCOUNT"
}